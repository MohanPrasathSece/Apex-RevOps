{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/client"
      }
    }
  ],
  "routes": [
    {
      "src": "/_nitro/(.*)",
      "dest": "/_nitro/$1"
    },
    {
      "src": "/(.*)",
      "dest": "dist/server/server.js"
    }
  ]
}
